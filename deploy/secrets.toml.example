# Copiar a deploy/secrets.toml en el servidor (fuera de git).
# cp deploy/secrets.toml.example deploy/secrets.toml

[users.admin]
password = "CAMBIAR_ADMIN"
rol = "admin"
nombre = "Administrador"

[users.superadmin]
password = "CAMBIAR_SUPERADMIN"
rol = "superadmin"
nombre = "Superadministrador"

[users.user]
password = "CAMBIAR_USER"
rol = "user"
nombre = "Usuario"

[iusasol]
client_id = "CAMBIAR"
client_secret = "CAMBIAR"
company_key = "system"
grant_type = "password"
encrypted = "false"
# base_url = "https://api.iusasol.mx/v2.1/api"
# tym = "2"
# tye = "E"

