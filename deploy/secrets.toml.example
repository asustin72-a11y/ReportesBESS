# Copiar a deploy/secrets.toml en el servidor (fuera de git).
# cp deploy/secrets.toml.example deploy/secrets.toml

[users.admin]
password = "CAMBIAR_ADMIN"
rol = "admin"
nombre = "Administrador"

[users.user]
password = "CAMBIAR_USER"
rol = "user"
nombre = "Usuario"

[iusasol]
client_id = "CAMBIAR"
client_secret = "CAMBIAR"
company_key = "system"
grant_type = "password"
encrypted = "false"
