# Copiar a secrets.toml (gitignored) para desarrollo local o Streamlit Cloud.
# En Cloud: Settings → Secrets → pegar este contenido con contraseñas reales.

[users.admin]
password = "CAMBIAR"
rol = "admin"
nombre = "Administrador"

[users.superadmin]
password = "CAMBIAR"
rol = "superadmin"
nombre = "Superadministrador"

[users.user]
password = "CAMBIAR"
rol = "user"
nombre = "Usuario"

# API IUSASOL (ISOL) — scripts/listar_medidores_iusasol.py
# Alternativa: variables IUSASOL_CLIENT_ID e IUSASOL_CLIENT_SECRET
[iusasol]
client_id = "CAMBIAR"
client_secret = "CAMBIAR"
company_key = "system"
grant_type = "password"
encrypted = "false"
# base_url = "https://api.iusasol.mx/v2.1/api"
# Perfil ISOL (energía en kWh):
# tym = "2"   # escala: 0=W, 1=Wh, 2=kWh, 3=MWh, 4=GWh
# tye = "E"   # E=energía, P=potencia

# Descarga pcarga (Mantenimiento DB → pestaña PCarga).
# Local Windows: basta con tener pcarga.py en disco (se detecta solo).
# Servidor Docker: Wine/MLE están en el host → SSH obligatorio:
# [pcarga]
# script = "/home/bess/mle/leeperfil/pcarga.py"
# mle_dir = "/home/bess/mle"
# ssh_host = "172.17.0.1"          # gateway Docker → host (o IP LAN del servidor)
# ssh_user = "bess"
# ssh_password = "CAMBIAR"
# auto_fallback = true            # tras fallo API: pcarga IUSA 1/2 en el sync (opt-in)
# Alternativa: PCARGA_SCRIPT / MLE_DIR / PCARGA_SSH_* / PCARGA_AUTO_FALLBACK=1
